<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.java_royal.controllers.TrueFalseController"
            prefHeight="700.0" prefWidth="980.0" styleClass="tof-root">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <center>
        <VBox alignment="CENTER" spacing="16.0" BorderPane.alignment="CENTER">
            <Label text="True or False - Clash Royale" styleClass="tof-title"/>
            <Label fx:id="questionLabel" styleClass="tof-question" text="Chargement..." wrapText="true"/>

            <HBox alignment="CENTER" spacing="12.0">
                <Button fx:id="trueButton" text="Vrai" onAction="#handleTrueAnswer" styleClass="true-button"/>
                <Button fx:id="falseButton" text="Faux" onAction="#handleFalseAnswer" styleClass="false-button"/>
            </HBox>

            <Label fx:id="scoreLabel" styleClass="tof-hud" text="Score : 0/10"/>
            <Label fx:id="progressLabel" styleClass="tof-hud" text="Question 1/10   Temps : 00:00"/>
            <Label fx:id="statusLabel" styleClass="tof-status" text="Reponds Vrai ou Faux !"/>

            <HBox alignment="CENTER" spacing="12.0">
                <Button text="Ajouter une question" onAction="#handleAddQuestion"/>
                <Button text="Rejouer" onAction="#handleReplay"/>
                <Button text="Retour Accueil" onAction="#backToHome"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>

