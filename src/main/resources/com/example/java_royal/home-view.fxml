<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.java_royal.controllers.HomeController">

    <!-- TOP : Barre d'information avec bienvenue, niveau et XP -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: rgba(31, 111, 235, 0.95); -fx-border-color: #FFD700; -fx-border-width: 0 0 3 0; -fx-effect: dropshadow(gaussian, #000000, 5, 0.7, 0, 3);">

            <!-- Message de bienvenue -->
            <Label fx:id="welcomeLabel" text="Bienvenue [Username] !"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 24; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, #000000, 5, 0.8, 0, 2);">
                <font>
                    <Font name="Arial" size="24"/>
                </font>
            </Label>

            <!-- Conteneur pour Niveau et XP -->
            <HBox spacing="30" alignment="CENTER_LEFT">

                <!-- Badge Niveau -->
                <VBox alignment="CENTER" spacing="5"
                      style="-fx-border-color: #FFD700; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-color: rgba(255, 215, 0, 0.1); -fx-padding: 10 20;">
                    <Label text="Niveau" style="-fx-text-fill: #CCCCCC; -fx-font-size: 12;"/>
                    <Label fx:id="levelBadge" text="1"
                           style="-fx-text-fill: #FFD700; -fx-font-size: 28; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Barre de progression XP -->
                <VBox spacing="5" HBox.hgrow="ALWAYS" maxWidth="400">
                    <Label text="Progression XP" style="-fx-text-fill: #CCCCCC; -fx-font-size: 12;"/>
                    <ProgressBar fx:id="xpProgressBar" prefHeight="20"
                                 style="-fx-accent: #FFD700; -fx-control-inner-background: #333333; -fx-padding: 2;"/>
                    <Label fx:id="xpLabel" text="0 / 100 XP"
                           style="-fx-text-fill: #AAAAAA; -fx-font-size: 11;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- CENTRE : Placeholder pour arène (le background est géré par le code) -->
    <center>
        <VBox alignment="CENTER" style="-fx-background-color: transparent;">
            <Label fx:id="arenaPlaceholder" text="⚔️ ARÈNE ⚔️"
                   style="-fx-text-fill: rgba(255, 215, 0, 0.6); -fx-font-size: 72; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, #000000, 10, 0.9, 0, 0);"/>
        </VBox>
    </center>

    <!-- BOTTOM : Boutons d'action -->
    <bottom>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-background-color: rgba(31, 111, 235, 0.95); -fx-border-color: #FFD700; -fx-border-width: 3 0 0 0; -fx-effect: dropshadow(gaussian, #000000, 5, 0.7, 0, -3);">

            <Button text="Pendu" prefWidth="180" prefHeight="45" onAction="#handleOpenPendu"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: yellow; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="Sudoku" prefWidth="180" prefHeight="45" onAction="#handleSudoku"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: yellow; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="Flappy Bird" prefWidth="180" prefHeight="45" onAction="#handleOpenFlappyBird"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: yellow; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="True or False" prefWidth="180" prefHeight="45" onAction="#handleOpenTrueOrFalse"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: yellow; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="Memory" prefWidth="180" prefHeight="45" onAction="#handleOpenMemory"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: yellow; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <HBox HBox.hgrow="ALWAYS" />

            <Button text="Classement" prefWidth="180" prefHeight="45" onAction="#handleLeaderboard"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: white; -fx-text-fill: #333333; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="Profil" prefWidth="180" prefHeight="45" onAction="#handleOpenProfile"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>

            <Button text="Quitter" prefWidth="180" prefHeight="45" onAction="#handleLogout"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-color: red; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>
        </HBox>
    </bottom>

</BorderPane>
