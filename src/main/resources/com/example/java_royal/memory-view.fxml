<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import com.example.java_royal.model.DifficultyLevel?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.java_royal.controllers.MemoryController"
            prefHeight="760.0" prefWidth="980.0" styleClass="memory-root">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/>
    </padding>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <Label text="Mode Memory" styleClass="memory-title"/>
            <Label fx:id="movesLabel" text="Coups : 0" styleClass="memory-hud"/>
            <Label text="Temps :" styleClass="memory-hud"/>
            <Label fx:id="timeLabel" text="00:00" styleClass="memory-hud"/>
            <Label text="Difficulté :" styleClass="memory-hud"/>
            <ComboBox fx:id="difficultyCombo" prefWidth="100.0"/>
            <Button text="Rejouer" onAction="#handleRestart"/>
            <Button text="Retour" onAction="#handleBackToHome"/>
        </HBox>
    </top>

    <center>
        <StackPane alignment="CENTER" BorderPane.alignment="CENTER">
            <GridPane fx:id="memoryGrid" alignment="CENTER" hgap="12.0" vgap="12.0"/>
            <Label fx:id="victoryLabel" managed="false" visible="false" styleClass="memory-victory-overlay"/>
        </StackPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Trouve les 12 paires !" styleClass="memory-status" BorderPane.alignment="CENTER_LEFT"/>
    </bottom>
</BorderPane>

