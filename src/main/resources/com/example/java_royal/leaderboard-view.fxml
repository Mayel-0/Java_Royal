<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.example.java_royal.controllers.LeaderboardController"
            style="-fx-background-color: #1a1a2e;">

    <!-- TOP : Titre du classement -->
    <top>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: rgba(31, 111, 235, 0.95); -fx-border-color: #FFD700; -fx-border-width: 0 0 3 0; -fx-effect: dropshadow(gaussian, #000000, 5, 0.7, 0, 3);">
            <Label text="👑 CLASSEMENT 👑"
                   style="-fx-text-fill: #FFD700; -fx-font-size: 32; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, #000000, 5, 0.8, 0, 2);"
                   alignment="CENTER">
                <font>
                    <Font name="Arial Black" size="32"/>
                </font>
            </Label>
            <Label text="Top joueurs par expérience totale"
                   style="-fx-text-fill: #CCCCCC; -fx-font-size: 14; -fx-effect: dropshadow(gaussian, #000000, 3, 0.6, 0, 1);"
                   alignment="CENTER">
                <font>
                    <Font name="Arial" size="14"/>
                </font>
            </Label>
        </VBox>
    </top>

    <!-- CENTRE : Tableau du classement -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">
            <TableView fx:id="leaderboardTable" style="-fx-font-family: Arial; -fx-font-size: 12;"
                       prefHeight="400">
                <columns>
                    <!-- Colonne Rang -->
                    <TableColumn fx:id="rankColumn" text="Rang" prefWidth="80">
                        <style>
                            -fx-alignment: CENTER;
                            -fx-font-weight: bold;
                        </style>
                    </TableColumn>

                    <!-- Colonne Pseudo -->
                    <TableColumn fx:id="usernameColumn" text="Pseudo" prefWidth="150">
                        <style>
                            -fx-alignment: CENTER_LEFT;
                        </style>
                    </TableColumn>

                    <!-- Colonne Niveau -->
                    <TableColumn fx:id="levelColumn" text="Niveau" prefWidth="100">
                        <style>
                            -fx-alignment: CENTER;
                            -fx-font-weight: bold;
                        </style>
                    </TableColumn>

                    <!-- Colonne XP Totale -->
                    <TableColumn fx:id="totalXpColumn" text="XP Totale" prefWidth="150">
                        <style>
                            -fx-alignment: CENTER;
                            -fx-font-weight: bold;
                        </style>
                    </TableColumn>
                </columns>
                <style>
                    /* Stylisation du header de la table */
                    -fx-header-style: center;

                    /* Lignes alternées : bleu et gris foncé */
                    -fx-table-cell-border-color: #333333;
                    -fx-border-color: #FFD700;
                    -fx-border-width: 2;

                    /* Couleur du texte */
                    -fx-text-fill: #FFFFFF;
                    -fx-control-inner-background: #2a2a4e;
                </style>
            </TableView>
        </VBox>
    </center>

    <!-- BOTTOM : Bouton Retour -->
    <bottom>
        <HBox spacing="10" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: rgba(31, 111, 235, 0.95); -fx-border-color: #FFD700; -fx-border-width: 3 0 0 0; -fx-effect: dropshadow(gaussian, #000000, 5, 0.7, 0, -3);">
            <Button text="← Retour à l'accueil" prefWidth="200" prefHeight="45" onAction="#goBackHome"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: linear-gradient(135deg, #6c757d 0%, #5a6268 100%); -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #000000, 5, 0.5, 0, 2);"/>
        </HBox>
    </bottom>

</BorderPane>

