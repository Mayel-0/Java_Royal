<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@true_false.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javaroyal.games.t_or_f.TrueFalseController">
    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <Label fx:id="questionLabel" styleClass="question-label" text="Question text will appear here." />
            <HBox alignment="CENTER" spacing="10.0">
                <Button fx:id="trueButton" onAction="#handleAnswer" text="Vrai" />
                <Button fx:id="falseButton" onAction="#handleAnswer" text="Faux" />
            </HBox>
            <Label fx:id="scoreLabel" styleClass="score-label" text="Score: 0" />
            <Button onAction="#handleBack" text="Retour" />
            <Button fx:id="replayButton" onAction="#replayGame" text="Rejouer" visible="false" />
        </VBox>
    </center>
    <bottom>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" />
            </padding>
            <Label styleClass="text-truefalse" text="Ajouter une nouvelle question" />
            <TextField  styleClass="input-truefalse" fx:id="newQuestionField" promptText="Texte de la question" />
            <CheckBox styleClass="text-truefalse"  fx:id="newQuestionAnswer" text="Réponse correcte (cocher pour Vrai)" />
            <Button onAction="#addQuestion" text="Ajouter" />
        </VBox>
    </bottom>
</BorderPane>

